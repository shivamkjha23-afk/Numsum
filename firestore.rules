rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function userRole() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().data.role in ['member','admin','super_admin'] ? userDoc().data.role : 'public'; }
    function isProfileCompleteUser() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc().data.profileComplete == true; }
    function isMember() { return signedIn() && userRole() in ['member','admin','super_admin']; }
    function isAdmin() { return userRole() in ['admin', 'super_admin']; }
    function safeUserRole(role) { return role in ['member','admin','super_admin']; }
    function elevatedUserRole(role) { return false; }
    function newMemberRoleReview() { return false; }
    function isSuperAdmin() { return userRole() == 'super_admin'; }
    function platformAdmin() { return isAdmin(); }
    function safeSelfProfileKeys() { return request.resource.data.diff(resource.data).changedKeys().hasOnly(['uid','displayName','name','fullName','email','phoneNumber','photoURL','role','roles','primaryRole','status','memberStatus','authProvider','provider','createdAt','profileComplete','profileCompletedAt','profileType','city','state','country','shortBio','professionalSummary','organizationId','organizationIds','organizationName','organizationType','industrySegment','manufacturingOrServiceFocus','productsOrServices','companySize','website','gstOrUdyam','majorChallenges','institutionName','departmentOrDiscipline','researchInterests','currentRole','portfolioOrLinkedIn','domainExpertise','yearsOfExperience','industriesWorkedWith','startupOrCompanyName','solutionArea','targetIndustries','productStage','skills','memberModuleEnabled','onboardingCompletedAt','updatedAt']); }
    function selfProfileRoleSafe() { return request.resource.data.role == resource.data.role || (!resource.data.keys().hasAny(['role']) && request.resource.data.role == 'member'); }
    function selfProfileStatusSafe() { return request.resource.data.status == resource.data.status || (!resource.data.keys().hasAny(['status']) && request.resource.data.status == 'active'); }
    function selfProfileRolesSafe() { return (!request.resource.data.diff(resource.data).changedKeys().hasAny(['roles']) || !request.resource.data.keys().hasAny(['roles']) || request.resource.data.roles == resource.data.roles || (!resource.data.keys().hasAny(['roles']) && containsOnlyMemberRoles(request.resource.data.roles))) && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['primaryRole']) || !request.resource.data.keys().hasAny(['primaryRole']) || request.resource.data.primaryRole == resource.data.primaryRole || (!resource.data.keys().hasAny(['primaryRole']) && request.resource.data.primaryRole == 'member')); }
    function adminRolePatchAllowed(uid) { return isSuperAdmin() && uid != request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['role','roles','primaryRole','status','memberStatus','updatedAt']) && (!request.resource.data.keys().hasAny(['role']) || safeUserRole(request.resource.data.role)) && (!request.resource.data.keys().hasAny(['roles']) || request.resource.data.roles.hasOnly(['member','admin','super_admin'])) && (!request.resource.data.keys().hasAny(['primaryRole']) || safeUserRole(request.resource.data.primaryRole)); }
    // Public reads require explicit public visibility and a safe externally publishable status.
    function isPublicDoc() { return resource.data.visibility == 'public' && resource.data.status in ['published', 'approved', 'completed', 'open', 'upcoming', 'closed', 'results_declared']; }
    function incomingPublicDoc() { return request.resource.data.visibility == 'public' && request.resource.data.status in ['published', 'approved', 'completed', 'open', 'upcoming', 'closed', 'results_declared']; }
    // Member-only records must still be in a safe lifecycle state; drafts/rejected/archived stay private.
    function memberVisible() { return signedIn() && resource.data.visibility == 'member_only' && resource.data.status in ['published', 'approved', 'completed', 'open', 'upcoming', 'closed', 'results_declared', 'active']; }
    function hasExistingList(field) { return resource.data.keys().hasAny([field]) && request.auth.uid in resource.data[field]; }
    function hasIncomingList(field) { return request.resource.data.keys().hasAny([field]) && request.auth.uid in request.resource.data[field]; }
    function teamVisible() { return signedIn() && resource.data.visibility == 'team_only' && (hasExistingList('teamMemberIds') || hasExistingList('members') || hasExistingList('ownerIds')); }
    function submitterVisible() { return signedIn() && (resource.data.createdBy == request.auth.uid || resource.data.submittedBy == request.auth.uid || resource.data.submitterId == request.auth.uid || hasExistingList('ownerIds')); }
    function canReadVisible() { return platformAdmin() || isPublicDoc() || memberVisible() || teamVisible() || submitterVisible(); }
    function containsOnlyMemberRoles(roles) { return roles is list && roles.size() == 1 && roles[0] == 'member'; }
    function noElevatedRoleFields() { return (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'member') && (!request.resource.data.keys().hasAny(['roles']) || containsOnlyMemberRoles(request.resource.data.roles)) && (!request.resource.data.keys().hasAny(['primaryRole']) || request.resource.data.primaryRole == 'member'); }
    function createsSelfProfile(uid) {
      return signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && noElevatedRoleFields()
        && request.resource.data.profileComplete == false
        && ((!request.resource.data.keys().hasAny(['memberStatus']) && request.resource.data.status == 'active') || request.resource.data.memberStatus in ['pending_profile_completion', 'active']);
    }
    function ownsExisting() { return signedIn() && (resource.data.createdBy == request.auth.uid || resource.data.submittedBy == request.auth.uid || resource.data.submitterId == request.auth.uid || resource.data.author == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.leader == request.auth.uid || hasExistingList('members') || hasExistingList('ownerIds')); }
    function ownsIncoming() { return signedIn() && (request.resource.data.createdBy == request.auth.uid || request.resource.data.submittedBy == request.auth.uid || request.resource.data.submittedByUserId == request.auth.uid || request.resource.data.submitterId == request.auth.uid || request.resource.data.author == request.auth.uid || request.resource.data.userId == request.auth.uid || request.resource.data.leader == request.auth.uid || hasIncomingList('members') || hasIncomingList('ownerIds')); }
    function problemSubmitterCreate() { return isProfileCompleteUser() && request.resource.data.submittedByUserId == request.auth.uid && request.resource.data.createdBy == request.auth.uid && request.resource.data.memberId == request.auth.uid && request.resource.data.status in ['draft','submitted'] && request.resource.data.visibility == 'submitter_only' && (!request.resource.data.keys().hasAny(['impactMetrics']) || (request.resource.data.impactMetrics.keys().hasOnly(['isPublic']) && request.resource.data.impactMetrics.isPublic == false)) && (!request.resource.data.keys().hasAny(['adminVisibilityFlags']) || request.resource.data.adminVisibilityFlags.meetingNotesVisibleToMemberDefault == false) && !request.resource.data.keys().hasAny(['adminNotes','internalNotes','adminInternalNotes','reviewNotes','reviewerNotes','approvedBy','approvedForPublic']); }
    function submitterEditableStatus() { return resource.data.status == 'draft'; }
    function hasSensitiveAdminFields() { return request.resource.data.keys().hasAny(['adminNotes','internalNotes','adminInternalNotes','reviewNotes','reviewerNotes','decisionNotes','privateFeedback','adminOnlySummary','reviewerComments']); }
    function submitterProblemPatchOnly() { return request.resource.data.diff(resource.data).changedKeys().hasOnly(['title','summary','shortDescription','detailedDescription','description','problemDescription','sector','industrySegment','category','subSector','subCategory','problemType','urgency','location','organizationName','companySize','currentProcess','affectedDepartment','affectedProcess','affectedProducts','questionnaireTemplateId','questionnaireAnswers','questionnaireResponses','impactEstimate','estimatedImpact','currentWorkaround','previousAttempts','expectedOutcome','evidenceLinks','attachmentsOrDriveLinks','attachments','dataAvailability','availableData','consentAccepted','contactConsent','tags','status','adminReviewStatus','submittedAt','updatedAt']) && request.resource.data.status in ['draft','submitted'] && request.resource.data.adminReviewStatus == request.resource.data.status && !request.resource.data.diff(resource.data).changedKeys().hasAny(['adminVisibilityFlags','impactMetrics','visibility','assignedAdminId','assignedReviewer','adminNotes','internalNotes','reviewNotes','reviewerNotes']); }
    function linkedProblem() { return get(/databases/$(database)/documents/problem_statements/$(resource.data.problemStatementId)); }
    function incomingLinkedProblem() { return get(/databases/$(database)/documents/problem_statements/$(request.resource.data.problemStatementId)); }
    function linkedProblemSubmitter() { return signedIn() && exists(/databases/$(database)/documents/problem_statements/$(resource.data.problemStatementId)) && (linkedProblem().data.createdBy == request.auth.uid || linkedProblem().data.submittedByUserId == request.auth.uid || linkedProblem().data.submitterId == request.auth.uid || request.auth.uid in linkedProblem().data.ownerIds); }
    function linkedOnboardingVisible() { return platformAdmin() || isPublicDoc() || memberVisible() || (linkedProblemSubmitter() && resource.data.visibility in ['submitter_only', 'member_only', 'public'] && resource.data.status in ['submitted','needs_more_info','published','approved','completed','active','open','upcoming','closed','results_declared']); }
    // Linked workspace reads follow the linked problem owner plus safe visibility/status checks.
    function linkedWorkspaceVisible() { return platformAdmin() || isPublicDoc() || memberVisible() || (linkedProblemSubmitter() && resource.data.visibility in ['submitter_only', 'member_only', 'public'] && resource.data.status in ['submitted','needs_more_info','published','approved','completed','active','open','upcoming','closed','results_declared']); }
    function safeWorkspaceCreate() { return platformAdmin() && request.resource.data.visibility in ['admin_only', 'submitter_only', 'member_only', 'public']; }

    function threadDoc(threadId) { return get(/databases/$(database)/documents/discussion_threads/$(threadId)); }
    function discussionPublicOpen() { return resource.data.visibility == 'public' && resource.data.status == 'open' && (!resource.data.keys().hasAny(['moderationStatus']) || resource.data.moderationStatus in ['clean','approved']); }
    function discussionMemberReadable() { return isProfileCompleteUser() && resource.data.visibility == 'members' && !(resource.data.status in ['hidden','under_review']); }
    function discussionTeamReadable() { return signedIn() && resource.data.visibility == 'private_team' && (platformAdmin() || hasExistingList('teamMemberIds') || hasExistingList('participantIds')); }
    function discussionProblemReadable() { return signedIn() && resource.data.visibility == 'private_problem' && (platformAdmin() || resource.data.authorId == request.auth.uid || hasExistingList('problemOwnerIds') || hasExistingList('assignedUserIds') || hasExistingList('participantIds')); }
    function canReadDiscussion() { return platformAdmin() || discussionPublicOpen() || discussionMemberReadable() || discussionTeamReadable() || discussionProblemReadable(); }
    function publicChallengeStatus() { return resource.data.visibility == 'public' && resource.data.status in ['published','open','registration_closed','submission_closed','evaluation','results_declared']; }
    function incomingChallengeTeam() { return get(/databases/$(database)/documents/challenge_teams/$(request.resource.data.teamId)); }
    function existingChallengeTeam() { return get(/databases/$(database)/documents/challenge_teams/$(resource.data.teamId)); }
    function challengeSubmissionAdminFields() { return ['marks','rank','adminComments','evaluatedBy','evaluatedAt','resultApproved','evaluationStatus']; }
    function safeChallengeSubmissionCreate() { return isProfileCompleteUser() && request.resource.data.submittedByMemberId == request.auth.uid && exists(/databases/$(database)/documents/challenge_teams/$(request.resource.data.teamId)) && request.auth.uid in incomingChallengeTeam().data.acceptedMemberIds && request.resource.data.status in ['draft','submitted'] && request.resource.data.locked == (request.resource.data.status == 'submitted') && !request.resource.data.keys().hasAny(challengeSubmissionAdminFields()); }
    function safeChallengeSubmissionUpdate() { return signedIn() && exists(/databases/$(database)/documents/challenge_teams/$(resource.data.teamId)) && request.auth.uid in existingChallengeTeam().data.acceptedMemberIds && resource.data.status == 'draft' && request.resource.data.teamId == resource.data.teamId && request.resource.data.challengeId == resource.data.challengeId && request.resource.data.submittedByMemberId == resource.data.submittedByMemberId && request.resource.data.status in ['draft','submitted'] && request.resource.data.locked == (request.resource.data.status == 'submitted') && !request.resource.data.diff(resource.data).changedKeys().hasAny(challengeSubmissionAdminFields()); }
    function invitedTeamAcceptPatch() { return isProfileCompleteUser() && resource.data.keys().hasAny(['invitedMemberIds']) && request.auth.uid in resource.data.invitedMemberIds && request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds','acceptedMemberIds','memberMembershipIds','invitedMemberIds','status','updatedAt']) && request.auth.uid in request.resource.data.memberIds && request.auth.uid in request.resource.data.acceptedMemberIds && !(request.auth.uid in request.resource.data.invitedMemberIds) && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 && request.resource.data.acceptedMemberIds.size() == resource.data.acceptedMemberIds.size() + 1 && request.resource.data.memberIds.size() <= resource.data.maxTeamSize && request.resource.data.challengeId == resource.data.challengeId && request.resource.data.leaderMemberId == resource.data.leaderMemberId && request.resource.data.maxTeamSize == resource.data.maxTeamSize; }
    function invitedTeamRejectPatch() { return isProfileCompleteUser() && resource.data.keys().hasAny(['invitedMemberIds']) && request.auth.uid in resource.data.invitedMemberIds && request.resource.data.diff(resource.data).changedKeys().hasOnly(['rejectedMemberIds','invitedMemberIds','updatedAt']) && request.auth.uid in request.resource.data.rejectedMemberIds && !(request.auth.uid in request.resource.data.invitedMemberIds) && request.resource.data.rejectedMemberIds.size() == resource.data.rejectedMemberIds.size() + 1 && request.resource.data.challengeId == resource.data.challengeId && request.resource.data.leaderMemberId == resource.data.leaderMemberId && request.resource.data.maxTeamSize == resource.data.maxTeamSize; }
    function safeProblemPublicReviewCreate() { return isProfileCompleteUser() && request.resource.data.memberId == request.auth.uid && request.resource.data.approvedForPublic == false && (!request.resource.data.keys().hasAny(['adminTags']) || request.resource.data.adminTags.size() == 0) && (!request.resource.data.keys().hasAny(['moderationStatus']) || request.resource.data.moderationStatus == 'pending') && !request.resource.data.keys().hasAny(['approvedBy','reviewedBy','reviewedAt','updatedBy']); }
    function safeProblemPublicReviewUpdate() { return signedIn() && resource.data.memberId == request.auth.uid && resource.data.approvedForPublic == false && !request.resource.data.diff(resource.data).changedKeys().hasAny(['approvedForPublic','moderationStatus','adminTags','approvedBy','reviewedBy','reviewedAt','updatedBy']); }
    function safeCaseStudyCommentCreate() { return isProfileCompleteUser() && request.resource.data.memberId == request.auth.uid && request.resource.data.status == 'pending'; }
    function safeDiscussionCreate() { return isProfileCompleteUser() && request.resource.data.authorId == request.auth.uid && !(request.resource.data.visibility in ['admin_only']) && !(request.resource.data.status in ['hidden','locked','archived']) && request.resource.data.moderationStatus == 'clean' && ((request.resource.data.visibility == 'public' && request.resource.data.status == 'under_review') || (request.resource.data.visibility != 'public' && request.resource.data.status == 'open')); }
    function safeThreadUpdate() { return signedIn() && resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['title','body','summary','tags','updatedAt']) && !(resource.data.status in ['hidden','under_review','archived','locked']); }
    function parentThreadReadable(threadId) { return exists(/databases/$(database)/documents/discussion_threads/$(threadId)) && (platformAdmin() || (threadDoc(threadId).data.visibility == 'public' && threadDoc(threadId).data.status == 'open' && (!threadDoc(threadId).data.keys().hasAny(['moderationStatus']) || threadDoc(threadId).data.moderationStatus in ['clean','approved'])) || (isProfileCompleteUser() && threadDoc(threadId).data.visibility == 'members' && !(threadDoc(threadId).data.status in ['hidden','under_review'])) || (signedIn() && threadDoc(threadId).data.visibility == 'private_team' && (request.auth.uid in threadDoc(threadId).data.teamMemberIds || request.auth.uid in threadDoc(threadId).data.participantIds)) || (signedIn() && threadDoc(threadId).data.visibility == 'private_problem' && (threadDoc(threadId).data.authorId == request.auth.uid || request.auth.uid in threadDoc(threadId).data.problemOwnerIds || request.auth.uid in threadDoc(threadId).data.assignedUserIds || request.auth.uid in threadDoc(threadId).data.participantIds))); }
    function parentThreadCommentable(threadId) { return parentThreadReadable(threadId) && (platformAdmin() || threadDoc(threadId).data.status == 'open'); }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || platformAdmin());
      allow create: if createsSelfProfile(uid) || platformAdmin();
      allow update: if (signedIn() && uid == request.auth.uid && request.resource.data.uid == uid && selfProfileRoleSafe() && selfProfileRolesSafe() && selfProfileStatusSafe() && safeSelfProfileKeys()) || adminRolePatchAllowed(uid);
      allow delete: if isSuperAdmin();
    }

    match /bootstrap_admins/{email} { allow read, write: if isSuperAdmin(); }
    match /system_documents/{id} { allow read: if true; allow write: if platformAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if platformAdmin(); }
    match /role_definitions/{id} { allow read: if signedIn(); allow write: if platformAdmin(); }
    match /system_stats/{id} { allow read: if true; allow write: if platformAdmin(); }
    match /public_metrics/{id} { allow read: if true; allow write: if platformAdmin(); }
    match /audit_logs/{id} { allow read: if platformAdmin(); allow create: if signedIn(); allow update: if isSuperAdmin() || (platformAdmin() && id == '__schema'); allow delete: if isSuperAdmin(); }
    match /admin_audit_logs/{id} { allow read, create: if isSuperAdmin(); allow update, delete: if false; }

    match /notifications/{id} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admins' && platformAdmin()) || platformAdmin());
      allow create: if signedIn();
      allow update: if platformAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow delete: if platformAdmin();
    }

    match /admin_inbox/{id} { allow read, update, delete: if platformAdmin(); allow create: if signedIn(); }
    match /user_role_requests/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.userId == request.auth.uid); allow create, update, delete: if false; }
    match /role_requests/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.userId == request.auth.uid); allow create, update, delete: if false; }

    match /admin_applications/{id} { allow read: if platformAdmin(); allow create, update, delete: if false; }

    match /problem_statements/{id} {
      // Admins can manage all problem records. Public reads are restricted to published public summaries.
      // Submitters can read their own private submissions and edit only safe intake fields before review closes.
      allow read: if platformAdmin()
        || (resource.data.visibility == 'public' && resource.data.status == 'published')
        || (signedIn() && resource.data.visibility == 'member_only' && resource.data.status in ['approved','published','active'])
        || submitterVisible();
      allow create: if (platformAdmin() && !hasSensitiveAdminFields()) || problemSubmitterCreate();
      allow update: if platformAdmin()
        || (submitterVisible()
          && submitterEditableStatus()
          && submitterProblemPatchOnly()
          && request.resource.data.visibility == resource.data.visibility
          && request.resource.data.assignedAdminId == resource.data.assignedAdminId);
      allow delete: if platformAdmin();
    }
    // Legacy /challenges documents are not used for new reads; ProblemStatement remains canonical.
    match /challenges/{document=**} { allow read, write: if platformAdmin(); }
    match /problem_reviews/{id} { allow read: if platformAdmin() || submitterVisible(); allow create, update, delete: if platformAdmin(); }
    match /problem_reviews_public/{id} { allow read: if platformAdmin() || (resource.data.approvedForPublic == true && resource.data.consentForPublicDisplay == true) || (signedIn() && resource.data.memberId == request.auth.uid); allow create: if safeProblemPublicReviewCreate(); allow update: if platformAdmin() || safeProblemPublicReviewUpdate(); allow delete: if platformAdmin(); }

    match /research_posts/{id} {
      function approvedResearch() { return resource.data.status in ['approved','published','public']; }
      function nonAdminSafeResearchCreate() { return isProfileCompleteUser() && ownsIncoming() && request.resource.data.status == 'under_review' && request.resource.data.visibility == 'admin_only' && !(request.resource.data.keys().hasAny(['problemStatementId']) && request.resource.data.problemStatementId != null && request.resource.data.problemStatementId != ''); }
      function nonAdminSafeResearchUpdate() { return ownsExisting() && request.resource.data.status == resource.data.status && request.resource.data.visibility == resource.data.visibility && !(request.resource.data.status in ['approved','published','public']) && request.resource.data.visibility != 'public' && request.resource.data.problemStatementId == resource.data.problemStatementId; }
      allow read: if platformAdmin() || ownsExisting() || (resource.data.visibility == 'public' && approvedResearch()) || (signedIn() && resource.data.visibility == 'member_only' && approvedResearch()) || linkedWorkspaceVisible();
      allow create: if platformAdmin() || nonAdminSafeResearchCreate();
      allow update: if platformAdmin() || nonAdminSafeResearchUpdate();
      allow delete: if platformAdmin();
    }
    match /knowledge_assets/{id} { allow read: if canReadVisible() || linkedWorkspaceVisible(); allow create: if platformAdmin() || (isProfileCompleteUser() && ownsIncoming() && request.resource.data.problemStatementId is string && request.resource.data.status == 'under_review' && request.resource.data.visibility == 'admin_only'); allow update: if platformAdmin() || (ownsExisting() && request.resource.data.status == resource.data.status && request.resource.data.visibility == resource.data.visibility && !(request.resource.data.status in ['approved','published']) && request.resource.data.visibility != 'public'); allow delete: if platformAdmin(); }
    match /sop_documents/{id} { allow read: if canReadVisible() || linkedWorkspaceVisible(); allow create, update, delete: if platformAdmin() && request.resource.data.problemStatementId is string && !hasSensitiveAdminFields(); }
    match /pilot_tracks/{id} { allow read: if platformAdmin() || (resource.data.visibility == 'public' && resource.data.status in ['completed','scaled']) || (signedIn() && resource.data.visibility == 'member_only' && resource.data.status in ['active','completed','scaled']) || (linkedProblemSubmitter() && resource.data.visibility in ['submitter_only','member_only','public']); allow create, update, delete: if platformAdmin() && request.resource.data.problemStatementId is string && !hasSensitiveAdminFields(); }
    match /pilot_milestones/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if platformAdmin() && request.resource.data.problemStatementId is string && !hasSensitiveAdminFields(); }
    match /pilot_updates/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if platformAdmin() && request.resource.data.problemStatementId is string && !hasSensitiveAdminFields(); }
    match /pilot_metrics/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if platformAdmin() && request.resource.data.problemStatementId is string && !hasSensitiveAdminFields(); }
    match /meeting_logs/{id} { allow read: if linkedOnboardingVisible(); allow write: if platformAdmin() && !hasSensitiveAdminFields(); }
    match /problem_meeting_notes/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.visibleToMember == true && exists(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)) && (get(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)).data.memberId == request.auth.uid || get(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)).data.submittedByUserId == request.auth.uid)); allow create, update, delete: if platformAdmin(); }
    match /linked_resources/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if safeWorkspaceCreate(); }
    match /timeline_events/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if safeWorkspaceCreate(); }
    match /file_links/{id} { allow read: if linkedWorkspaceVisible(); allow create, update, delete: if safeWorkspaceCreate(); }
    match /problem_onboarding_sessions/{id} { allow read: if linkedOnboardingVisible(); allow write: if platformAdmin() && !hasSensitiveAdminFields(); }
    match /questionnaire_responses/{id} { allow read: if linkedOnboardingVisible(); allow write: if platformAdmin() && !hasSensitiveAdminFields(); }
    match /problem_questionnaire_responses/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.visibleToMember == true && exists(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)) && (get(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)).data.memberId == request.auth.uid || get(/databases/$(database)/documents/problem_statements/$(resource.data.problemId)).data.submittedByUserId == request.auth.uid)); allow create, update: if platformAdmin() && !hasSensitiveAdminFields(); allow delete: if platformAdmin(); }
    match /problem_meeting_note_pdfs/{id} { allow read: if platformAdmin(); allow create, update, delete: if false; }
    match /success_stories/{id} { allow read: if platformAdmin() || (resource.data.visibility == 'public' && resource.data.status == 'published'); allow create, update, delete: if platformAdmin(); }
    match /testimonial_ratings/{id} { allow read: if canReadVisible(); allow create: if signedIn(); allow update, delete: if platformAdmin(); }
    match /case_studies/{id} { allow read: if platformAdmin() || (resource.data.status == 'published' && resource.data.approvedForPublic == true); allow create, update, delete: if platformAdmin(); }
    match /case_study_comments/{id} { allow read: if platformAdmin() || resource.data.status == 'approved' || (signedIn() && resource.data.memberId == request.auth.uid); allow create: if safeCaseStudyCommentCreate(); allow update: if platformAdmin() || (signedIn() && resource.data.memberId == request.auth.uid && resource.data.status == 'pending' && request.resource.data.diff(resource.data).changedKeys().hasOnly(['body','updatedAt'])); allow delete: if platformAdmin() || (signedIn() && resource.data.memberId == request.auth.uid && resource.data.status == 'pending'); }
    match /case_study_upvotes/{id} { allow read: if true; allow create: if isProfileCompleteUser() && request.resource.data.memberId == request.auth.uid; allow delete: if platformAdmin() || (signedIn() && resource.data.memberId == request.auth.uid); allow update: if false; }

    match /discussion_threads/{id} {
      allow read: if canReadDiscussion();
      allow create: if platformAdmin() || safeDiscussionCreate();
      allow update: if platformAdmin() || safeThreadUpdate();
      allow delete: if platformAdmin();
    }
    match /discussion_comments/{id} {
      allow read: if resource.data.status == 'visible' && parentThreadReadable(resource.data.threadId);
      allow create: if isProfileCompleteUser() && request.resource.data.authorId == request.auth.uid && request.resource.data.status == 'visible' && request.resource.data.moderationStatus == 'clean' && parentThreadCommentable(request.resource.data.threadId);
      allow update: if platformAdmin() || (signedIn() && resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['body','editedAt','updatedAt']) && resource.data.status == 'visible');
      allow delete: if platformAdmin();
    }
    match /discussion_reports/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.reportedBy == request.auth.uid); allow create: if isProfileCompleteUser() && request.resource.data.reportedBy == request.auth.uid && request.resource.data.status == 'open'; allow update, delete: if platformAdmin(); }
    match /moderation_actions/{id} { allow read, write: if platformAdmin(); }

    match /community_posts/{id} { allow read: if platformAdmin() || (resource.data.visibility == 'public' && resource.data.status == 'approved') || (signedIn() && resource.data.authorId == request.auth.uid); allow create: if platformAdmin() || (isProfileCompleteUser() && request.resource.data.authorId == request.auth.uid && request.resource.data.status == 'pending' && !request.resource.data.keys().hasAny(['approvedBy','approvedAt','moderationNotes'])); allow update, delete: if platformAdmin(); }
    match /comments/{id} { allow read: if true; allow create: if isProfileCompleteUser() && ownsIncoming(); allow update, delete: if platformAdmin() || ownsExisting(); }
    match /replies/{id} { allow read: if signedIn(); allow create: if isProfileCompleteUser() && ownsIncoming(); allow update, delete: if platformAdmin() || ownsExisting(); }
    match /community_analytics/{id} { allow read: if platformAdmin(); allow create, update: if signedIn(); allow delete: if platformAdmin(); }
    match /collaboration_requests/{id} { allow read: if platformAdmin() || ownsExisting(); allow create: if platformAdmin() || (signedIn() && ownsIncoming()); allow update, delete: if platformAdmin() || ownsExisting(); }

    match /competitions/{id} { allow read: if platformAdmin() || publicChallengeStatus() || memberVisible(); allow create, update, delete: if platformAdmin(); }
    match /competition_teams/{id} { allow read, write: if platformAdmin(); }
    match /competition_participations/{id} { allow read, write: if platformAdmin(); }
    match /competition_submissions/{id} { allow read, write: if platformAdmin(); }
    match /competition_evaluations/{id} { allow read, write: if platformAdmin(); }
    match /challenge_participations/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.memberId == request.auth.uid); allow create: if isProfileCompleteUser() && request.resource.data.memberId == request.auth.uid && request.resource.data.status in ['registered','active']; allow update: if platformAdmin() || (signedIn() && resource.data.memberId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','updatedAt']) && request.resource.data.status in ['registered','active','withdrawn']); allow delete: if platformAdmin(); }
    match /challenge_teams/{id} { allow read: if platformAdmin() || (signedIn() && (request.auth.uid in resource.data.memberIds || request.auth.uid in resource.data.acceptedMemberIds || (resource.data.keys().hasAny(['invitedMemberIds']) && request.auth.uid in resource.data.invitedMemberIds))); allow create: if isProfileCompleteUser() && request.resource.data.leaderMemberId == request.auth.uid && request.auth.uid in request.resource.data.memberIds && request.auth.uid in request.resource.data.acceptedMemberIds && request.resource.data.memberIds.size() <= request.resource.data.maxTeamSize; allow update: if platformAdmin() || (signedIn() && resource.data.leaderMemberId == request.auth.uid) || invitedTeamAcceptPatch() || invitedTeamRejectPatch(); allow delete: if platformAdmin(); }
    match /challenge_team_invites/{id} { allow read: if platformAdmin() || (signedIn() && (resource.data.invitedMemberId == request.auth.uid || resource.data.invitedByMemberId == request.auth.uid)); allow create: if isProfileCompleteUser() && request.resource.data.invitedByMemberId == request.auth.uid && request.resource.data.status == 'pending'; allow update: if platformAdmin() || (signedIn() && resource.data.invitedMemberId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','respondedAt','updatedAt']) && request.resource.data.status in ['accepted','rejected']); allow delete: if platformAdmin(); }
    match /challenge_submissions/{id} { allow read: if platformAdmin() || (signedIn() && exists(/databases/$(database)/documents/challenge_teams/$(resource.data.teamId)) && request.auth.uid in existingChallengeTeam().data.acceptedMemberIds); allow create: if safeChallengeSubmissionCreate(); allow update: if platformAdmin() || safeChallengeSubmissionUpdate(); allow delete: if platformAdmin(); }
    match /challenge_evaluations/{id} { allow read: if platformAdmin(); allow create, update, delete: if platformAdmin(); }
    match /challenge_results/{id} { allow read: if platformAdmin() || (resource.data.approvedForPublic == true); allow create, update, delete: if platformAdmin(); }

    match /competition_results/{id} { allow read, write: if platformAdmin(); }

    match /organizations/{id} { allow read: if platformAdmin(); allow create: if signedIn(); allow update, delete: if platformAdmin(); }
    match /team_members/{id} { allow read: if platformAdmin(); allow create, update, delete: if platformAdmin(); }
    match /questionnaire_templates/{id} { allow read: if platformAdmin() || (resource.data.status == 'active' && resource.data.usageType == 'problem_submission'); allow create, update, delete: if platformAdmin(); }
    match /constitution_documents/{id} { allow read, write: if platformAdmin(); }
    match /objective_target_documents/{id} { allow read, write: if platformAdmin(); }
    match /governance_documents/{id} { allow read, write: if platformAdmin(); }
    match /governance_document_versions/{id} { allow read, write: if platformAdmin(); }
    match /governance_amendments/{id} { allow read, write: if platformAdmin(); }
    match /objective_targets/{id} { allow read, write: if platformAdmin(); }
    match /governance_audit_events/{id} { allow read, write: if platformAdmin(); }
    match /problem_admin_metadata/{id} { allow read, write: if platformAdmin(); }
    match /onboarding_admin_metadata/{id} { allow read, write: if platformAdmin(); }
    match /pilot_admin_metadata/{id} { allow read, write: if platformAdmin(); }
    match /competition_submission_admin_metadata/{id} { allow read, write: if platformAdmin(); }
    match /contribution_review_metadata/{id} { allow read, write: if platformAdmin(); }

    function assignedExisting() { return signedIn() && (hasExistingList('ownerIds') || hasExistingList('reviewerIds') || hasExistingList('attendees')); }
    function assignedIncoming() { return signedIn() && (hasIncomingList('ownerIds') || hasIncomingList('reviewerIds') || hasIncomingList('attendees')); }
    function memberExecutionPatchOnly() { return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'completionNotes', 'blockerReason', 'evidenceLinks', 'updatedAt']); }
    match /execution_work_items/{id} { allow read: if platformAdmin() || assignedExisting(); allow create, delete: if platformAdmin(); allow update: if platformAdmin() || (assignedExisting() && memberExecutionPatchOnly()); }
    match /action_items/{id} { allow read: if platformAdmin() || assignedExisting(); allow create, delete: if platformAdmin(); allow update: if platformAdmin() || (assignedExisting() && memberExecutionPatchOnly()); }
    match /meeting_records/{id} { allow read: if platformAdmin() || assignedExisting(); allow create, delete: if platformAdmin(); allow update: if platformAdmin() || (assignedExisting() && resource.data.status != 'completed' && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status','updatedAt'])); }
    match /execution_reviews/{id} { allow read, write: if platformAdmin(); }
    match /decision_records/{id} { allow read: if platformAdmin(); allow write: if platformAdmin(); }
    match /evidence_records/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.visibility == 'internal_member' && resource.data.uploadedBy == request.auth.uid); allow create: if platformAdmin() || (signedIn() && request.resource.data.uploadedBy == request.auth.uid && request.resource.data.visibility == 'internal_member'); allow update, delete: if platformAdmin(); }

    function contributionOwner() { return signedIn() && resource.data.contributorUserId == request.auth.uid; }
    function contributionIncomingOwner() { return signedIn() && request.resource.data.contributorUserId == request.auth.uid; }
    function internalContributionVisible() { return isMember() && resource.data.visibility == 'internal_member'; }
    function claimEditableByOwner() { return signedIn() && resource.data.contributorUserId == request.auth.uid && resource.data.status in ['submitted','needs_revision']; }
    function claimSafeOwnerPatch() { return request.resource.data.contributorUserId == resource.data.contributorUserId && request.resource.data.status == resource.data.status && !request.resource.data.keys().hasAny(['approvedScore','reviewerId','reviewerName','reviewedAt']); }
    match /contribution_records/{id} { allow read: if platformAdmin() || contributionOwner(); allow create, update, delete: if platformAdmin(); }
    match /contribution_score_rules/{id} { allow read: if platformAdmin() || (isMember() && resource.data.active == true); allow create, update, delete: if platformAdmin(); }
    match /contribution_review_cycles/{id} { allow read, write: if platformAdmin(); }
    match /contributor_review_summaries/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.contributorUserId == request.auth.uid && resource.data.finalStatus == 'finalized'); allow create, update, delete: if platformAdmin(); }
    match /recognition_records/{id} { allow read: if platformAdmin() || (signedIn() && resource.data.contributorUserId == request.auth.uid) || internalContributionVisible(); allow create, update, delete: if platformAdmin(); }
    match /contribution_claims/{id} { allow read: if platformAdmin() || contributionOwner(); allow create: if isProfileCompleteUser() && contributionIncomingOwner() && request.resource.data.status == 'submitted' && !request.resource.data.keys().hasAny(['approvedScore','reviewerId','reviewerName','reviewedAt']); allow update: if platformAdmin() || (claimEditableByOwner() && claimSafeOwnerPatch()); allow delete: if platformAdmin(); }

    match /internal_threads/{id} { allow read, write: if platformAdmin(); }
    match /career_openings/{id} { allow read: if true; allow write: if platformAdmin(); }
    match /career_applications/{id} { allow create: if true; allow read, update, delete: if platformAdmin(); }
    match /private_collaboration_groups/{id} { allow read, write: if signedIn() && (platformAdmin() || ownsExisting() || ownsIncoming()); }
    match /bookmarks/{id} { allow read: if platformAdmin() || ownsExisting(); allow create: if platformAdmin() || (signedIn() && ownsIncoming()); allow update, delete: if platformAdmin() || ownsExisting(); }
    match /msme_cases/{id} { allow read: if isPublicDoc(); allow create, update, delete: if platformAdmin(); }

    match /{document=**} { allow read, write: if isSuperAdmin(); }
  }
}
