# NumSum deployment environment example
# Copy to .env.local for local development or add the same keys in Vercel.
# Do not commit .env.local, service-account JSON, private keys, or production secrets.

# Required Firebase Web/client SDK config (public by Firebase design; restrict the API key in Google Cloud).
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:replace-with-web-app-id

# Optional Firebase Analytics only. NumSum does not require Firebase Storage for MOM/PDF.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin / maintenance scripts only. Never prefix these with NEXT_PUBLIC_.
# Use one uncommitted service-account file or Application Default Credentials when running scripts.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/uncommitted-service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
GCLOUD_PROJECT=your-project-id
FIREBASE_PROJECT_ID=your-project-id

# Local emulator configuration for safe rules/script rehearsal.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Vercel/platform-provided values. Set manually only when reproducing deployment locally.
NODE_ENV=development
VERCEL_ENV=development
VERCEL_URL=localhost:3000
