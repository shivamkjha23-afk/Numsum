# NumSum Labs environment example
# Copy to .env.local for local development, or configure equivalent variables in Vercel/Firebase Hosting.
# Do not commit real .env.local, service account JSON, private keys, or production secrets.

# Required Firebase Web/client SDK config. These are safe to expose in browser bundles.
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:replace-with-app-id

# Optional Firebase Web config. Add only if the feature is enabled for the project.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-only/admin script configuration. Never prefix these with NEXT_PUBLIC_.
# Prefer GOOGLE_APPLICATION_CREDENTIALS pointing to a local, uncommitted service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-admin-service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
GCLOUD_PROJECT=your-project-id

# Local emulator configuration. Use for rules tests and safe local admin-script rehearsal.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Runtime/deployment platform variables. Usually set by the platform.
NODE_ENV=development
VERCEL_ENV=development
VERCEL_URL=
